# ── OUR app: Supabase / judgments (read-only source of truth) ──
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=            # service role — READ judgments, WRITE memchat schema
# Supabase deprecated direct (db.<ref>.supabase.co) connections — use the POOLER host.
# Find yours in Supabase → Project Settings → Database → Connection pooling (Session mode).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# ── OUR app: AI providers ──
ANTHROPIC_API_KEY=               # Claude — used by OUR code for the final legal answer
OPENAI_API_KEY=                  # also handed to Cognee as LLM_API_KEY
COHERE_API_KEY=                  # optional rerank
CLAUDE_MODEL_REASONING=claude-opus-4-8
CLAUDE_MODEL_FAST=claude-sonnet-4-6

# ── COGNEE: LLM for graph extraction (use OpenAI) ──
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ── COGNEE: embeddings — MUST be 1536 to match judgment_vectors ──
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# ── COGNEE: run the whole memory layer on ONE Postgres ──
# Point at a SEPARATE database (cognee_db) so Cognee never collides with judgments.
DB_PROVIDER=postgres
VECTOR_DB_PROVIDER=pgvector
GRAPH_DATABASE_PROVIDER=postgres     # swap to "neo4j" for the visual demo
CACHE_BACKEND=postgres
DB_HOST=aws-1-<region>.pooler.supabase.com
DB_PORT=5432
DB_USERNAME=postgres.<ref>
DB_PASSWORD=<password>
DB_NAME=cognee_db

# ── COGNEE: optional Neo4j (demo visual only) ──
GRAPH_DATABASE_URL=                  # bolt://...  only if GRAPH_DATABASE_PROVIDER=neo4j
GRAPH_DATABASE_USERNAME=
GRAPH_DATABASE_PASSWORD=

# ── Memory backend: local | cognee | auto ──
# local  = Postgres-native memory in the memchat schema (default; fully runnable now)
# cognee = real Cognee hybrid graph+vector memory (needs `pip install "cognee[postgres]"`
#          AND a dedicated cognee_db database)
# auto   = try cognee, fall back to local
MEMORY_BACKEND=local

# ── Retrieval knobs ──
HYBRID_SEARCH_LIMIT=20
RERANK_TOP_N=10

# ── Service ──
APP_HOST=0.0.0.0
APP_PORT=8000
ENVIRONMENT=production
DEBUG=false

# ── Auth (email/password works with NO config below) ──
# Google sign-in activates automatically once these two are set. Create an
# OAuth 2.0 Client (type "Web application") in Google Cloud Console and add this
# authorized redirect URI:  http://127.0.0.1:8000/api/auth/google/callback
# (add your production URL too when you deploy).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: force the public origin used to build the OAuth redirect URI
# (defaults to the request's own origin). e.g. https://app.example.com
OAUTH_REDIRECT_BASE=
# Session cookie lifetime in days.
AUTH_SESSION_DAYS=30

# ── Clerk (powers "Continue with Google") ──
# Publishable key is public (sent to the browser); secret key is server-only.
# In the Clerk Dashboard: enable Google under "User & Authentication → Social
# Connections", and add these Allowed redirect / SSO URLs for local dev:
#   http://127.0.0.1:8000/sso-callback   and   http://127.0.0.1:8000/
# The Frontend API is decoded from the publishable key automatically.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional: override the Clerk Frontend API host (else decoded from the pk).
CLERK_FRONTEND_API=
